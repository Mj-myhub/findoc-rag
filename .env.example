# Copy this file to ".env" and fill in your keys.
# NEVER commit the real .env file — it is git-ignored.

# Groq — free LLM API, used from Phase 2 (generation).
# Get a free key at: https://console.groq.com
GROQ_API_KEY=

# Hugging Face token — optional, only needed for gated models
# or for pushing artifacts to the Hub. Get one at:
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Langfuse — free observability, used from Phase 3.
# Get keys at: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
